{
    "family": "auth",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "taskRoleArn": "arn:aws:iam::945488516083:role/ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::945488516083:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "auth",
            "image": "945488516083.dkr.ecr.ap-south-1.amazonaws.com/mealstack-auth:e912493836013882022dd6dfb4901611528a5ec6",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 4001,
                    "hostPort": 4001,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "PORT",
                    "value": "4001"
                },
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "CORS_ORIGINS",
                    "value": "*"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "MONGO_URI",
                    "valueFrom": "arn:aws:secretsmanager:ap-south-1:945488516083:secret:mealstack/auth/MONGO_URI-DFsk6v"
                },
                {
                    "name": "JWT_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:ap-south-1:945488516083:secret:mealstack/auth/JWT_SECRET-GbJJZI"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/mealstack-cluster",
                    "awslogs-region": "ap-south-1",
                    "awslogs-stream-prefix": "auth"
                }
            },
            "systemControls": []
        }
    ]
}
