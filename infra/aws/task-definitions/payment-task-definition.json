{
    "family": "payment",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "taskRoleArn": "arn:aws:iam::945488516083:role/ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::945488516083:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "payment",
            "image": "945488516083.dkr.ecr.eu-north-1.amazonaws.com/mealstack-auth:e912493836013882022dd6dfb4901611528a5ec6",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 4004,
                    "hostPort": 4004,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "PORT",
                    "value": "4004"
                },
                {
                    "name": "CHECKOUT_CANCEL_URL",
                    "value": "http://localhost:3000/payment/cancel"
                },
                {
                    "name": "CHECKOUT_SUCCESS_URL",
                    "value": "http://localhost:3000/payment/success"
                },
                {
                    "name": "INTERNAL_API_KEY",
                    "value": "prod-internal-key-change-me-later"
                },
                {
                    "name": "AUTH_SERVICE_URL",
                    "value": "http://mealstack-alb-1494783241.eu-north-1.elb.amazonaws.com"
                },
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "CORS_ORIGINS",
                    "value": "*"
                },
                {
                    "name": "ORDER_SERVICE_URL",
                    "value": "http://mealstack-alb-1494783241.eu-north-1.elb.amazonaws.com"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "MONGO_URI",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:945488516083:secret:mealstack/payment/MONGO_URI-TZyjOy"
                },
                {
                    "name": "JWT_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:945488516083:secret:mealstack/auth/JWT_SECRET-rHriv3"
                },
                {
                    "name": "STRIPE_SECRET_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:945488516083:secret:mealstack/payment/STRIPE_SECRET_KEY-nJBGOS"
                },
                {
                    "name": "STRIPE_WEBHOOK_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:945488516083:secret:mealstack/payment/STRIPE_WEBHOOK_SECRET-ZiOHSi"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/mealstack-cluster",
                    "awslogs-region": "eu-north-1",
                    "awslogs-stream-prefix": "payment"
                }
            },
            "systemControls": []
        }
    ]
}
