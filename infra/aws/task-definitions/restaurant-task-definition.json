{
    "family": "restaurant",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "taskRoleArn": "arn:aws:iam::013052902701:role/ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::013052902701:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "restaurant",
            "image": "013052902701.dkr.ecr.us-east-1.amazonaws.com/mealstack-auth:restaurant-e912493836013882022dd6dfb4901611528a5ec6",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 4002,
                    "hostPort": 4002,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "PORT",
                    "value": "4002"
                },
                {
                    "name": "AUTH_SERVICE_URL",
                    "value": "http://auth-service.mealstack.local:4001"
                },
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "CORS_ORIGINS",
                    "value": "*"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "MONGO_URI",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:013052902701:secret:mealstack/restaurant/MONGO_URI-d5opw7"
                },
                {
                    "name": "JWT_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:013052902701:secret:mealstack/auth/JWT_SECRET-8sTCad"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/mealstack-cluster",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "restaurant"
                }
            },
            "systemControls": []
        }
    ]
}
