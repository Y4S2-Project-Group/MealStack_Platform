{
    "family": "rider",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "taskRoleArn": "arn:aws:iam::945488516083:role/ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::945488516083:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "rider",
            "image": "945488516083.dkr.ecr.ap-south-1.amazonaws.com/mealstack-auth:e912493836013882022dd6dfb4901611528a5ec6",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 4005,
                    "hostPort": 4005,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "AUTH_SERVICE_URL",
                    "value": "http://mealstack-alb-1222463843.ap-south-1.elb.amazonaws.com"
                },
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "CORS_ORIGINS",
                    "value": "*"
                },
                {
                    "name": "ORDER_SERVICE_URL",
                    "value": "http://mealstack-alb-1222463843.ap-south-1.elb.amazonaws.com"
                },
                {
                    "name": "PORT",
                    "value": "4005"
                },
                {
                    "name": "INTERNAL_API_KEY",
                    "value": "prod-internal-key-change-me-later"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "MONGO_URI",
                    "valueFrom": "arn:aws:secretsmanager:ap-south-1:945488516083:secret:mealstack/rider/MONGO_URI-mBr0jr"
                },
                {
                    "name": "JWT_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:ap-south-1:945488516083:secret:mealstack/auth/JWT_SECRET-GbJJZI"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/mealstack-cluster",
                    "awslogs-region": "ap-south-1",
                    "awslogs-stream-prefix": "rider"
                }
            },
            "systemControls": []
        }
    ]
}
