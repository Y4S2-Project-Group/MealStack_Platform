{
    "family": "order",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "taskRoleArn": "arn:aws:iam::013052902701:role/ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::013052902701:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "order",
            "image": "013052902701.dkr.ecr.us-east-1.amazonaws.com/mealstack-auth:e912493836013882022dd6dfb4901611528a5ec6",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 4003,
                    "hostPort": 4003,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "PAYMENT_SERVICE_URL",
                    "value": "http://payment-service.mealstack.local:4004"
                },
                {
                    "name": "PORT",
                    "value": "4003"
                },
                {
                    "name": "RESTAURANT_SERVICE_URL",
                    "value": "http://restaurant-service.mealstack.local:4002"
                },
                {
                    "name": "INTERNAL_API_KEY",
                    "value": "prod-internal-key-change-me-later"
                },
                {
                    "name": "AUTH_SERVICE_URL",
                    "value": "http://auth-service.mealstack.local:4001"
                },
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "RIDER_SERVICE_URL",
                    "value": "http://rider-service.mealstack.local:4005"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "MONGO_URI",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:013052902701:secret:mealstack/order/MONGO_URI-ARnmon"
                },
                {
                    "name": "JWT_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:013052902701:secret:mealstack/auth/JWT_SECRET-8sTCad"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/mealstack-cluster",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "order"
                }
            },
            "systemControls": []
        }
    ]
}
