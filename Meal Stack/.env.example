# MealStack Frontend Environment Variables
# Copy this file to .env.local for local development

# API Base URL
# For LOCAL development: Point to AWS ALB
VITE_API_BASE_URL=http://mealstack-alb-1222463843.ap-south-1.elb.amazonaws.com

# For VERCEL production: Leave empty (uses vercel.json rewrites)
# VITE_API_BASE_URL=

# API timeout in milliseconds
VITE_API_TIMEOUT_MS=10000
